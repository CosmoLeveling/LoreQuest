{
  "name":"Dracula",
  "colors": {
    "primary":        "#bd93f9",
    "secondary":      "#ff79c6",
    "background":     "#282a36",
    "surface":        "#343746",
    "overlay":        "#44475a",
    "on_primary":     "#282a36",
    "on_background":  "#f8f8f2",
    "muted":          "#6272a4",
    "error":          "#ff5555",
    "success":        "#50fa7b",
    "warning":        "#f1fa8c",
    "cyan":           "#8be9fd",
    "orange":         "#ffb86c"
  },
  "fonts": {
    "default": "res://fonts/CaveatBrush-Regular.ttf",
    "bold":    "res://fonts/CaveatBrush-Regular.ttf",
    "mono":    "res://fonts/CaveatBrush-Regular.ttf"
  },
  "font_sizes": {
    "xs": 10, "sm": 12, "base": 14, "md": 16, "lg": 20, "xl": 26, "heading": 32
  },
  "control_colors": {
    "Label": { "font_color": "#f8f8f2" },
    "TabBar": {
      "font_selected_color":   "#bd93f9",
      "font_unselected_color": "#6272a4"
    },
    "TabContainer": {
      "font_selected_color":   "#bd93f9",
      "font_unselected_color": "#6272a4"
    }
  },
  "grid": {
    "grid_size":        40,
    "background_color": "#282a36",
    "minor_color":      "#6272a480",
    "major_color":      "#bd93f9aa",
    "axis_color":       "#ff79c6ff",
    "major_line_every": 5
  },
  "styleboxes": {
    "Button": {
      "normal":   { "bg_color": "#44475a", "border_color": "#bd93f9", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] },
      "hover":    { "bg_color": "#6272a4", "border_color": "#bd93f9", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] },
      "pressed":  { "bg_color": "#bd93f9", "border_color": "#bd93f9", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] },
      "disabled": { "bg_color": "#343746", "border_color": "#44475a", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] }
    },
    "PanelContainer": { "panel": { "bg_color": "#343746", "border_color": "#44475a", "border_width": 1, "corner_radius": 10, "content_margin": [16, 16, 16, 16] } },
    "Panel":          { "panel": { "bg_color": "#343746", "border_color": "#44475a", "border_width": 1, "corner_radius": 0, "content_margin": [16, 16, 16, 16] } },
    "LineEdit": {
      "normal":    { "bg_color": "#282a36", "border_color": "#44475a", "border_width": 1, "corner_radius": 5, "content_margin": [10, 6, 10, 6] },
      "focus":     { "bg_color": "#282a36", "border_color": "#bd93f9", "border_width": 1, "corner_radius": 5, "content_margin": [10, 6, 10, 6] },
      "read_only": { "bg_color": "#343746", "border_color": "#44475a", "border_width": 1, "corner_radius": 5, "content_margin": [10, 6, 10, 6] }
    },
    "TextEdit": {
      "normal":    { "bg_color": "#282a36", "border_color": "#44475a", "border_width": 1, "corner_radius": 5, "content_margin": [10, 8, 10, 8] },
      "focus":     { "bg_color": "#282a36", "border_color": "#bd93f9", "border_width": 1, "corner_radius": 5, "content_margin": [10, 8, 10, 8] },
      "read_only": { "bg_color": "#343746", "border_color": "#44475a", "border_width": 1, "corner_radius": 5, "content_margin": [10, 8, 10, 8] }
    },
    "TabContainer": {
      "tab_selected":   { "bg_color": "#44475a", "border_color": "#bd93f9", "border_width": 1, "corner_radius": 5, "content_margin": [12, 6, 12, 6] },
      "tab_unselected": { "bg_color": "#282a36", "border_color": "#44475a", "border_width": 1, "corner_radius": 5, "content_margin": [12, 6, 12, 6] },
      "tab_hover":      { "bg_color": "#6272a4", "border_color": "#6272a4", "border_width": 1, "corner_radius": 5, "content_margin": [12, 6, 12, 6] },
      "panel":          { "bg_color": "#343746", "border_color": "#44475a", "border_width": 1, "corner_radius": 0, "content_margin": [8, 8, 8, 8] }
    },
    "HSeparator": { "separator": { "bg_color": "#6272a4", "thickness": 1 } },
    "ProgressBar": {
      "background": { "bg_color": "#44475a", "border_color": "#6272a4", "border_width": 1, "corner_radius": 5, "content_margin": [0, 0, 0, 0] },
      "fill":       { "bg_color": "#bd93f9", "border_color": "#bd93f9", "border_width": 0, "corner_radius": 5, "content_margin": [0, 0, 0, 0] }
    }
  }
}
