{
  "colors": {
    "primary":        "#d79921",
    "secondary":      "#689d6a",
    "background":     "#282828",
    "surface":        "#3c3836",
    "overlay":        "#504945",
    "on_primary":     "#282828",
    "on_background":  "#ebdbb2",
    "muted":          "#665c54",
    "subtle":         "#7c6f64",
    "error":          "#cc241d",
    "success":        "#98971a",
    "warning":        "#d79921",
    "orange":         "#d65d0e",
    "aqua":           "#689d6a"
  },
  "fonts": {
    "default": "res://fonts/CaveatBrush-Regular.ttf",
    "bold":    "res://fonts/CaveatBrush-Regular.ttf",
    "mono":    "res://fonts/CaveatBrush-Regular.ttf"
  },
  "font_sizes": {
    "xs": 10, "sm": 12, "base": 14, "md": 16, "lg": 20, "xl": 26, "heading": 32
  },
  "control_colors": {
    "Label": { "font_color": "#ebdbb2" },
    "TabBar": {
      "font_selected_color":   "#d79921",
      "font_unselected_color": "#7c6f64"
    },
    "TabContainer": {
      "font_selected_color":   "#d79921",
      "font_unselected_color": "#7c6f64"
    }
  },
  "grid": {
    "grid_size":        40,
    "background_color": "#282828",
    "minor_color":      "#50494580",
    "major_color":      "#d79921aa",
    "axis_color":       "#d65d0eff",
    "major_line_every": 5
  },
  "styleboxes": {
    "Button": {
      "normal":   { "bg_color": "#3c3836", "border_color": "#d79921", "border_width": 1, "corner_radius": 4, "content_margin": [16, 8, 16, 8] },
      "hover":    { "bg_color": "#504945", "border_color": "#d79921", "border_width": 1, "corner_radius": 4, "content_margin": [16, 8, 16, 8] },
      "pressed":  { "bg_color": "#d79921", "border_color": "#d79921", "border_width": 1, "corner_radius": 4, "content_margin": [16, 8, 16, 8] },
      "disabled": { "bg_color": "#3c3836", "border_color": "#504945", "border_width": 1, "corner_radius": 4, "content_margin": [16, 8, 16, 8] }
    },
    "PanelContainer": { "panel": { "bg_color": "#3c3836", "border_color": "#504945", "border_width": 1, "corner_radius": 6, "content_margin": [16, 16, 16, 16] } },
    "Panel":          { "panel": { "bg_color": "#3c3836", "border_color": "#504945", "border_width": 1, "corner_radius": 6, "content_margin": [16, 16, 16, 16] } },
    "LineEdit": {
      "normal":    { "bg_color": "#282828", "border_color": "#504945", "border_width": 1, "corner_radius": 4, "content_margin": [10, 6, 10, 6] },
      "focus":     { "bg_color": "#282828", "border_color": "#d79921", "border_width": 1, "corner_radius": 4, "content_margin": [10, 6, 10, 6] },
      "read_only": { "bg_color": "#3c3836", "border_color": "#504945", "border_width": 1, "corner_radius": 4, "content_margin": [10, 6, 10, 6] }
    },
    "TextEdit": {
      "normal":    { "bg_color": "#282828", "border_color": "#504945", "border_width": 1, "corner_radius": 4, "content_margin": [10, 8, 10, 8] },
      "focus":     { "bg_color": "#282828", "border_color": "#d79921", "border_width": 1, "corner_radius": 4, "content_margin": [10, 8, 10, 8] },
      "read_only": { "bg_color": "#3c3836", "border_color": "#504945", "border_width": 1, "corner_radius": 4, "content_margin": [10, 8, 10, 8] }
    },
    "TabContainer": {
      "tab_selected":   { "bg_color": "#3c3836", "border_color": "#d79921", "border_width": 1, "corner_radius": 4, "content_margin": [12, 6, 12, 6] },
      "tab_unselected": { "bg_color": "#282828", "border_color": "#504945", "border_width": 1, "corner_radius": 4, "content_margin": [12, 6, 12, 6] },
      "tab_hover":      { "bg_color": "#504945", "border_color": "#665c54", "border_width": 1, "corner_radius": 4, "content_margin": [12, 6, 12, 6] },
      "panel":          { "bg_color": "#3c3836", "border_color": "#504945", "border_width": 1, "corner_radius": 0, "content_margin": [8, 8, 8, 8] }
    },
    "HSeparator": { "separator": { "bg_color": "#504945", "thickness": 1 } },
    "ProgressBar": {
      "background": { "bg_color": "#3c3836", "border_color": "#504945", "border_width": 1, "corner_radius": 4, "content_margin": [0, 0, 0, 0] },
      "fill":       { "bg_color": "#d79921", "border_color": "#d79921", "border_width": 0, "corner_radius": 4, "content_margin": [0, 0, 0, 0] }
    }
  }
}
