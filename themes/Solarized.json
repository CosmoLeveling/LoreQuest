{
  "colors": {
    "primary":        "#268bd2",
    "secondary":      "#2aa198",
    "background":     "#002b36",
    "surface":        "#073642",
    "overlay":        "#0d4a57",
    "on_primary":     "#002b36",
    "on_background":  "#839496",
    "muted":          "#586e75",
    "subtle":         "#657b83",
    "error":          "#dc322f",
    "success":        "#859900",
    "warning":        "#b58900",
    "magenta":        "#d33682",
    "violet":         "#6c71c4"
  },
  "fonts": {
    "default": "res://fonts/CaveatBrush-Regular.ttf",
    "bold":    "res://fonts/CaveatBrush-Regular.ttf",
    "mono":    "res://fonts/CaveatBrush-Regular.ttf"
  },
  "font_sizes": {
    "xs": 10, "sm": 12, "base": 14, "md": 16, "lg": 20, "xl": 26, "heading": 32
  },
  "control_colors": {
    "Label": { "font_color": "#93a1a1" },
    "TabBar": {
      "font_selected_color":   "#268bd2",
      "font_unselected_color": "#586e75"
    },
    "TabContainer": {
      "font_selected_color":   "#268bd2",
      "font_unselected_color": "#586e75"
    }
  },
  "grid": {
    "grid_size":        40,
    "background_color": "#002b36",
    "minor_color":      "#073642cc",
    "major_color":      "#268bd2aa",
    "axis_color":       "#2aa198ff",
    "major_line_every": 5
  },
  "styleboxes": {
    "Button": {
      "normal":   { "bg_color": "#073642", "border_color": "#268bd2", "border_width": 1, "corner_radius": 5, "content_margin": [16, 8, 16, 8] },
      "hover":    { "bg_color": "#0d4a57", "border_color": "#268bd2", "border_width": 1, "corner_radius": 5, "content_margin": [16, 8, 16, 8] },
      "pressed":  { "bg_color": "#268bd2", "border_color": "#268bd2", "border_width": 1, "corner_radius": 5, "content_margin": [16, 8, 16, 8] },
      "disabled": { "bg_color": "#073642", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 5, "content_margin": [16, 8, 16, 8] }
    },
    "PanelContainer": { "panel": { "bg_color": "#073642", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 8, "content_margin": [16, 16, 16, 16] } },
    "Panel":          { "panel": { "bg_color": "#073642", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 0, "content_margin": [16, 16, 16, 16] } },
    "LineEdit": {
      "normal":    { "bg_color": "#002b36", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 4, "content_margin": [10, 6, 10, 6] },
      "focus":     { "bg_color": "#002b36", "border_color": "#268bd2", "border_width": 1, "corner_radius": 4, "content_margin": [10, 6, 10, 6] },
      "read_only": { "bg_color": "#073642", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 4, "content_margin": [10, 6, 10, 6] }
    },
    "TextEdit": {
      "normal":    { "bg_color": "#002b36", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 4, "content_margin": [10, 8, 10, 8] },
      "focus":     { "bg_color": "#002b36", "border_color": "#268bd2", "border_width": 1, "corner_radius": 4, "content_margin": [10, 8, 10, 8] },
      "read_only": { "bg_color": "#073642", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 4, "content_margin": [10, 8, 10, 8] }
    },
    "TabContainer": {
      "tab_selected":   { "bg_color": "#073642", "border_color": "#268bd2", "border_width": 1, "corner_radius": 4, "content_margin": [12, 6, 12, 6] },
      "tab_unselected": { "bg_color": "#002b36", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 4, "content_margin": [12, 6, 12, 6] },
      "tab_hover":      { "bg_color": "#0d4a57", "border_color": "#586e75", "border_width": 1, "corner_radius": 4, "content_margin": [12, 6, 12, 6] },
      "panel":          { "bg_color": "#073642", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 0, "content_margin": [8, 8, 8, 8] }
    },
    "HSeparator": { "separator": { "bg_color": "#0d4a57", "thickness": 1 } },
    "ProgressBar": {
      "background": { "bg_color": "#073642", "border_color": "#0d4a57", "border_width": 1, "corner_radius": 4, "content_margin": [0, 0, 0, 0] },
      "fill":       { "bg_color": "#268bd2", "border_color": "#268bd2", "border_width": 0, "corner_radius": 4, "content_margin": [0, 0, 0, 0] }
    }
  }
}
