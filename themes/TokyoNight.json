{
  "colors": {
    "primary":        "#7aa2f7",
    "secondary":      "#bb9af7",
    "background":     "#1a1b26",
    "surface":        "#24283b",
    "overlay":        "#292e42",
    "on_primary":     "#1a1b26",
    "on_background":  "#c0caf5",
    "muted":          "#414868",
    "subtle":         "#565f89",
    "error":          "#f7768e",
    "success":        "#9ece6a",
    "warning":        "#e0af68",
    "cyan":           "#7dcfff",
    "teal":           "#2ac3de"
  },
  "fonts": {
    "default": "res://fonts/CaveatBrush-Regular.ttf",
    "bold":    "res://fonts/CaveatBrush-Regular.ttf",
    "mono":    "res://fonts/CaveatBrush-Regular.ttf"
  },
  "font_sizes": {
    "xs": 10, "sm": 12, "base": 14, "md": 16, "lg": 20, "xl": 26, "heading": 32
  },
  "control_colors": {
    "Label": { "font_color": "#c0caf5" },
    "TabBar": {
      "font_selected_color":   "#7aa2f7",
      "font_unselected_color": "#565f89"
    },
    "TabContainer": {
      "font_selected_color":   "#7aa2f7",
      "font_unselected_color": "#565f89"
    }
  },
  "grid": {
    "grid_size":        40,
    "background_color": "#1a1b26",
    "minor_color":      "#29283580",
    "major_color":      "#7aa2f7aa",
    "axis_color":       "#bb9af7ff",
    "major_line_every": 5
  },
  "styleboxes": {
    "Button": {
      "normal":   { "bg_color": "#292e42", "border_color": "#7aa2f7", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] },
      "hover":    { "bg_color": "#414868", "border_color": "#7aa2f7", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] },
      "pressed":  { "bg_color": "#7aa2f7", "border_color": "#7aa2f7", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] },
      "disabled": { "bg_color": "#24283b", "border_color": "#414868", "border_width": 1, "corner_radius": 6, "content_margin": [16, 8, 16, 8] }
    },
    "PanelContainer": { "panel": { "bg_color": "#24283b", "border_color": "#292e42", "border_width": 1, "corner_radius": 10, "content_margin": [16, 16, 16, 16] } },
    "Panel":          { "panel": { "bg_color": "#24283b", "border_color": "#292e42", "border_width": 1, "corner_radius": 10, "content_margin": [16, 16, 16, 16] } },
    "LineEdit": {
      "normal":    { "bg_color": "#1a1b26", "border_color": "#414868", "border_width": 1, "corner_radius": 5, "content_margin": [10, 6, 10, 6] },
      "focus":     { "bg_color": "#1a1b26", "border_color": "#7aa2f7", "border_width": 1, "corner_radius": 5, "content_margin": [10, 6, 10, 6] },
      "read_only": { "bg_color": "#24283b", "border_color": "#292e42", "border_width": 1, "corner_radius": 5, "content_margin": [10, 6, 10, 6] }
    },
    "TextEdit": {
      "normal":    { "bg_color": "#1a1b26", "border_color": "#414868", "border_width": 1, "corner_radius": 5, "content_margin": [10, 8, 10, 8] },
      "focus":     { "bg_color": "#1a1b26", "border_color": "#7aa2f7", "border_width": 1, "corner_radius": 5, "content_margin": [10, 8, 10, 8] },
      "read_only": { "bg_color": "#24283b", "border_color": "#292e42", "border_width": 1, "corner_radius": 5, "content_margin": [10, 8, 10, 8] }
    },
    "TabContainer": {
      "tab_selected":   { "bg_color": "#292e42", "border_color": "#7aa2f7", "border_width": 1, "corner_radius": 5, "content_margin": [12, 6, 12, 6] },
      "tab_unselected": { "bg_color": "#1a1b26", "border_color": "#414868", "border_width": 1, "corner_radius": 5, "content_margin": [12, 6, 12, 6] },
      "tab_hover":      { "bg_color": "#414868", "border_color": "#565f89", "border_width": 1, "corner_radius": 5, "content_margin": [12, 6, 12, 6] },
      "panel":          { "bg_color": "#24283b", "border_color": "#292e42", "border_width": 1, "corner_radius": 0, "content_margin": [8, 8, 8, 8] }
    },
    "HSeparator": { "separator": { "bg_color": "#414868", "thickness": 1 } },
    "ProgressBar": {
      "background": { "bg_color": "#292e42", "border_color": "#414868", "border_width": 1, "corner_radius": 5, "content_margin": [0, 0, 0, 0] },
      "fill":       { "bg_color": "#7aa2f7", "border_color": "#7aa2f7", "border_width": 0, "corner_radius": 5, "content_margin": [0, 0, 0, 0] }
    }
  }
}
